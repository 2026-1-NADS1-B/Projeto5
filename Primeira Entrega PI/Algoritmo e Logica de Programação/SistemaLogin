algoritmo "SimulaçãoLogin"
// Disciplina  :  [Algoritmo e Lógica de Programação]
// Professor   : [Chico Escobar]
// Descrição   : [Simulador de Login para um sistema, onde o usuario(Escola) tem acesso a um sistema de pacote de jogos ativos e se o ip do usuario for diferente do ip cadastrado, o sistema bloqueia o acesso. O sistema também tem um contador de tentativas de login, onde o usuario tem 3 tentativas para acessar o sistema, caso contrário, o sistema bloqueia o acesso por 30 minutos]
// Autor(a)    : Guilherme Ryuki Kawahira

var
usuarioDigitado: caractere
senhaDigitada: caractere
ipDigitado: caractere
pacoteAtivo: logico
tentativas: inteiro
acessoOk: logico

inicio
usuarioDigitado <- "Escola_A"
senhaDigitada <- "123456"
ipDigitado <- "192.168.1.42"
pacoteAtivo <- verdadeiro
tentativas <- 0
acessoOk <- falso

se nao pacoteAtivo entao
    escreval("ERRO! Pacote de jogos inativo.")
    escreval("O pacote de jogos está inativo. Por favor, renove sua assinatura.")
senao
     escreval("Bem-vindo ao sistema de jogos! Por favor, faça login para acessar o catálogo de jogos.")
fimse

enquanto (tentativas < 3) e (pacoteAtivo = verdadeiro) e (nao acessoOK) faca
    escreval("Digite o nome de usuário: ")
    leia(usuarioDigitado)
    escreval("Digite a senha: ")
    leia(senhaDigitada)
    escreval("Digite o IP: ")
    leia(ipDigitado)

    se (usuarioDigitado = "Escola_A") e (senhaDigitada = "123456") e (ipDigitado = "192.168.1.42") entao
        escreval("Acesso concedido. Bem-vindo ao sistema!")
        acessoOk <- verdadeiro
        escreval(" +=======================+")
        escreval("     Catalogo de jogos    ")
        escreval(" +=======================+")
        escreval()
        escreval("1. Matematica Divertida")
        escreval("2. Qumica Magica")
        escreval("3. Fisica Engenhosa")
        escreval("4. História Interativa")
        escreval("5. Ciênias 3D")
    senao
        se (usuarioDigitado <> "Escola_A") entao
            escreval("Usuário incorreto.")
        senao 
            se (senhaDigitada <> "123456") entao
                escreval("Senha incorreta.")
            senao
                se (ipDigitado <> "192.168.1.42") entao
                    escreval("IP NÃO AUTORIZADO!")
                fimse
            fimse
        fimse

        tentativas <- tentativas + 1
        escreval("Acesso negado. Tentativa ", tentativas, " de 3.")
        se (tentativas = 3) entao
            pacoteAtivo <- falso
            escreva("Número máximo de tentativas atingido. Acesso bloqueado por 30 minutos.")
        fimse
    fimse
fimenquanto

fimalgoritmo
